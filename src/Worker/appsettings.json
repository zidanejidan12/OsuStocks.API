{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=osu_stocks;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "OpenTelemetry": {
    "ServiceName": "osustocks-worker",
    "OtlpEndpoint": ""
  },
  "OsuOAuth": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "https://localhost:5001/api/v1/auth/callback",
    "AuthorizationEndpoint": "https://osu.ppy.sh/oauth/authorize",
    "TokenEndpoint": "https://osu.ppy.sh/oauth/token",
    "Scopes": [ "public", "identify" ]
  },
  "OsuApi": {
    "BaseUrl": "https://osu.ppy.sh/api/v2/",
    "RequestsPerMinute": 600,
    "BurstSize": 30
  },
  "Jwt": {
    "Issuer": "osu-stocks",
    "Audience": "osu-stocks-client",
    "SigningKey": "replace-with-a-very-long-random-key-at-least-32-characters",
    "ExpirationMinutes": 60
  },
  "MarketEngine": {
    "InactivityThresholdDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
