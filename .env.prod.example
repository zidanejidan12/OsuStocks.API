# Copy to ".env" on the server and fill in. Used by docker-compose.prod.yml.
# Generate strong secrets, e.g.:  openssl rand -base64 36

# --- Domain ---
DOMAIN=osustocks.com
APP_ORIGIN=https://app.osustocks.com          # the frontend origin allowed by CORS

# --- Postgres ---
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# --- osu! OAuth (register at https://osu.ppy.sh/home/account/edit -> New OAuth Application) ---
OSUOAUTH_CLIENT_ID=
OSUOAUTH_CLIENT_SECRET=
OSUOAUTH_REDIRECT_URI=https://api.osustocks.com/api/v1/auth/callback

# --- JWT (must be >= 32 chars) ---
JWT_ISSUER=osu-stocks
JWT_AUDIENCE=osu-stocks-client
JWT_SIGNING_KEY=CHANGE_ME_at_least_32_characters_long

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_grafana_password
