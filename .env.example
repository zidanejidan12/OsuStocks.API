# =============================================================================
# OsuStocks Docker Compose Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to source control (.env is in .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# ASP.NET Core
# -----------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=replace-with-strong-database-password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Optional: set a password for Redis. Leave empty for no authentication.
# If set, update the connection string format below.
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# osu! OAuth
# -----------------------------------------------------------------------------
# Register an OAuth application at https://osu.ppy.sh/home/account/edit#oauth
OSUOAUTH_CLIENT_ID=your-osu-oauth-client-id
OSUOAUTH_CLIENT_SECRET=your-osu-oauth-client-secret
OSUOAUTH_REDIRECT_URI=https://api.yourdomain.com/api/v1/auth/callback

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_ISSUER=osu-stocks
JWT_AUDIENCE=osu-stocks-client
JWT_SIGNING_KEY=replace-with-a-random-key-at-least-32-characters-long

# -----------------------------------------------------------------------------
# CORS & OAuth Return URL
# -----------------------------------------------------------------------------
# Frontend origin (scheme + host + optional port). Used for both CORS and
# OAuth return URL validation. For multiple origins, add CORS_ORIGIN_1, etc.
# and map them in docker-compose.yml as Cors__AllowedOrigins__1.
CORS_ORIGIN=https://app.yourdomain.com

# -----------------------------------------------------------------------------
# Swagger (optional)
# -----------------------------------------------------------------------------
# Set to true to enable Swagger UI outside Development environment.
# SECURITY_ENABLE_SWAGGER=false

# -----------------------------------------------------------------------------
# Hangfire
# -----------------------------------------------------------------------------
# Hangfire uses the PostgreSQL connection above. No additional configuration
# is required. The dashboard is accessible at /hangfire and requires the
# Admin role (+ HTTPS in production).
