# deploy/Caddyfile — automatic HTTPS (Let's Encrypt) for OsuStocks.
# Caddy provisions + renews certs automatically. Replace the email below.
{
    email admin@osustocks.com
}

# Backend API
api.osustocks.com {
    reverse_proxy api:8080
}

# Grafana (observability) — the only other public surface.
grafana.osustocks.com {
    reverse_proxy grafana:3000
}

# Frontend (OsuStocks.Web / Next.js) — served at the apex (canonical).
# Requires an A record for the apex `osustocks.com` pointing at this server so
# Caddy can issue its cert.
osustocks.com {
    reverse_proxy web:3000
}

# Old subdomain → permanent redirect to the apex so there's one canonical URL.
app.osustocks.com {
    redir https://osustocks.com{uri} permanent
}
