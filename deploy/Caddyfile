# deploy/Caddyfile — automatic HTTPS (Let's Encrypt) for OsuStocks.
# Caddy provisions + renews certs automatically. Replace the email below.
{
    email admin@osustocks.com
}

# Backend API
api.osustocks.com {
    reverse_proxy api:8080
}

# Grafana (observability) — the only other public surface.
grafana.osustocks.com {
    reverse_proxy grafana:3000
}

# Frontend (OsuStocks.Web / Next.js) deploys separately and is NOT part of this
# compose stack. Once it runs (as a container named "web" on this network, or on
# another host), expose it here. Examples:
#
# app.osustocks.com {
#     reverse_proxy web:3000          # if the FE runs as a container on this network
# }
# osustocks.com {
#     redir https://app.osustocks.com{uri}
# }
