# deploy/Caddyfile — automatic HTTPS (Let's Encrypt) for OsuStocks.
# Caddy provisions + renews certs automatically. Replace the email below.
{
    email admin@osustocks.com
}

# Backend API
api.osustocks.com {
    reverse_proxy api:8080
}

# Grafana (observability) — the only other public surface.
grafana.osustocks.com {
    reverse_proxy grafana:3000
}

# Frontend (OsuStocks.Web / Next.js) — the "web" container on this network.
app.osustocks.com {
    reverse_proxy web:3000
}

# Bare domain → app. Uncomment once an A record for the apex `osustocks.com`
# points at this server (otherwise Caddy can't issue its cert).
# osustocks.com {
#     redir https://app.osustocks.com{uri}
# }
